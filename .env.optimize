# Claude Code Optimization Flags (Discovered via Source Audit)

# 1. Optimize MCP tool descriptions (Incremental loading via deltas)
# Saves ~5k-15k tokens in sessions with many MCP servers
CLAUDE_CODE_MCP_INSTR_DELTA=true

# 2. Disable redundant file injections
# Root CLAUDE.md is now <1KB, but disabling system-wide ones helps
# CLAUDE_CODE_DISABLE_CLAUDE_MDS=true 

# 3. UI Performance (Indirect token savings via speed)
CLAUDE_CODE_DISABLE_VIRTUAL_SCROLL=true
CLAUDE_CODE_DISABLE_TERMINAL_TITLE=true

# 4. Context Guard (Safety)
# Already used in hooks, but good to have as a baseline
# CLAUDE_CODE_MAX_CONTEXT_TOKENS=100000
