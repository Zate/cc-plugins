{
  "description": "Security Guard hooks for deterministic real-time validation during code changes and Bash execution.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/run-script.cmd\" pre-tool-guard",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/run-script.cmd\" post-write-scan",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
