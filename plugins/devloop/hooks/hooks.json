{
  "description": "Devloop workflow hooks - optimized for token usage and speed",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "if": "tool == 'Bash'",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" pre-tool-bash",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "if": "tool == 'Write' || tool == 'Edit'",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" post-tool-write",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
