{
  "description": "ctx persistent memory - session-start injects stored knowledge, writes happen via ctx binary directly",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
